TEST /// 
    S = (ZZ/3)[x,y,z,w]
    I = ideal(x^2+y^2+z^2+w^2, x*y+x*z+x*w+y*z+y*w+z*w)
    n = 3
    d = 3
    J = wittOverringIdeal(n, I)
    f = for i from 0 to n-1 list random(d, I)
    assert isSubset(ideal wittTupleToOverring f, J)
///

TEST /// 
    S = (ZZ/5)[x_1,x_2,x_3,y_1,y_2,y_3]
    W3S = witt(3,S)
    w1 = witt{x_1,x_2,x_3}
    frobenius(1,w1) == witt{x_1^5,x_2^5,x_3^5}    
///


TEST ///
    S = (ZZ/2)[x,y]
    f = x^2 + y^3
    I = ideal(f)
    J = findFrobeniusLiftConstraints(I)
    c=(entries vars ring J)#0#1
    use ring J
    J == ideal(c*x^2*y+x^4)
///
